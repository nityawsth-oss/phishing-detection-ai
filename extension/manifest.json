@@ -0,0 +1,39 @@
{
  "manifest_version": 3,
  "name": "AI Phishing Detector",
  "version": "2.0",
  "description": "Automatic real-time AI-powered phishing website detection",
  "permissions": [
    "activeTab",
    "tabs",
    "notifications",
    "storage"
  ],
  "host_permissions": [
    "http://*/*",
    "https://*/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon.png",
      "48": "icon.png",
      "128": "icon.png"
    }
  },
  "icons": {
    "16": "icon.png",
    "48": "icon.png",
    "128": "icon.png"
  },
  "content_scripts": [
    {
      "matches": ["http://*/*", "https://*/*"],
      "js": ["content.js"],
      "run_at": "document_end"
    }
  ]
}
